# PostgreSQL connection string from Neon (neon.tech) or Supabase (supabase.com)
# Example Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Example Supabase: postgresql://postgres:pass@db.xxxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

